{
  "name": "@vybestack/llxprt-code-agents",
  "version": "0.10.0",
  "description": "LLxprt Code Agents — agent runtime, chat loop, and subagent orchestration",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vybestack/llxprt-code.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internals.js": {
      "types": "./dist/src/internals.d.ts",
      "import": "./dist/src/internals.js"
    },
    "./app-service.js": {
      "types": "./dist/src/app-service.d.ts",
      "import": "./dist/src/app-service.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build_package.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:mutation:api": "stryker run stryker.conf.json",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@google/genai": "1.30.0",
    "@vybestack/llxprt-code-auth": "file:../auth",
    "@vybestack/llxprt-code-core": "file:../core",
    "@vybestack/llxprt-code-ide-integration": "file:../ide-integration",
    "@vybestack/llxprt-code-policy": "file:../policy",
    "@vybestack/llxprt-code-providers": "file:../providers",
    "@vybestack/llxprt-code-settings": "file:../settings",
    "@vybestack/llxprt-code-tools": "file:../tools",
    "diff": "^8.0.3",
    "fast-levenshtein": "^2.0.6",
    "undici": "^7.28.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^24.2.1",
    "@vybestack/llxprt-code-test-utils": "file:../test-utils",
    "fast-check": "^4.2.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/telemetry.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2021", "ES2022.Error"],
    "composite": false,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@vybestack/llxprt-code-telemetry": ["./index.ts"],
      "@vybestack/llxprt-code-telemetry/*": ["./src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}

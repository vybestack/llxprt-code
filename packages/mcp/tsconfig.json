{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/mcp.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2021", "ES2022.Error"],
    "composite": false,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@vybestack/llxprt-code-mcp": ["./index.ts"],
      "@vybestack/llxprt-code-core": ["../core/index.ts"],
      "@vybestack/llxprt-code-core/*": ["../core/src/*"],
      "@vybestack/llxprt-code-settings": ["../settings/index.ts"],
      "@vybestack/llxprt-code-settings/*": ["../settings/src/*"],
      "@vybestack/llxprt-code-tools": ["../tools/index.ts"],
      "@vybestack/llxprt-code-tools/*": ["../tools/src/*"]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.json",
    "../core/src/types/wasm.d.ts",
    "../settings/index.ts",
    "../settings/src/**/*.ts",
    "../tools/index.ts",
    "../tools/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "../settings/src/**/*.test.ts",
    "../settings/src/**/*.spec.ts",
    "../tools/src/**/*.test.ts",
    "../tools/src/**/*.spec.ts"
  ]
}

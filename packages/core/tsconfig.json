{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/core.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2021", "ES2022.Error"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@vybestack/llxprt-code-auth": ["../auth/src/index.ts"],
      "@vybestack/llxprt-code-core": ["./index.ts"],
      "@vybestack/llxprt-code-core/*": ["./src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [{ "path": "../auth" }]
}

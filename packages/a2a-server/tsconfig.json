{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "rootDir": "..",
    "paths": {
      "@vybestack/llxprt-code-core": ["../core/index.ts"],
      "@vybestack/llxprt-code-core/*": ["../core/src/*"],
      "@vybestack/llxprt-code-mcp": ["../mcp/dist/mcp/index.d.ts"],
      "@vybestack/llxprt-code-mcp/*": ["../mcp/dist/mcp/src/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "node_modules",
    "dist",
    "../mcp/src/**/*.test.ts",
    "../mcp/src/**/*.spec.ts"
  ],
  "references": [{ "path": "../core" }]
}

{
  "name": "@vybestack/llxprt-code-providers",
  "version": "0.10.0",
  "description": "LLxprt Code Providers — LLM provider implementations and management",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vybestack/llxprt-code.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./BaseProvider.js": "./dist/BaseProvider.js",
    "./IModel.js": "./dist/IModel.js",
    "./IProvider.js": "./dist/IProvider.js",
    "./IProviderManager.js": "./dist/IProviderManager.js",
    "./ITool.js": "./dist/ITool.js",
    "./ProviderContentGenerator.js": "./dist/ProviderContentGenerator.js",
    "./ProviderManager.js": "./dist/ProviderManager.js",
    "./providerConfigKeys.js": "./dist/providerConfigKeys.js",
    "./reasoning/reasoningUtils.js": "./dist/reasoning/reasoningUtils.js",
    "./tokenizers/AnthropicTokenizer.js": "./dist/tokenizers/AnthropicTokenizer.js",
    "./tokenizers/ITokenizer.js": "./dist/tokenizers/ITokenizer.js",
    "./tokenizers/OpenAITokenizer.js": "./dist/tokenizers/OpenAITokenizer.js",
    "./types.js": "./dist/types.js",
    "./types/IProviderConfig.js": "./dist/types/IProviderConfig.js",
    "./types/providerRuntime.js": "./dist/types/providerRuntime.js",
    "./utils/mediaUtils.js": "./dist/utils/mediaUtils.js"
  },
  "scripts": {
    "build": "node ../../scripts/build_package.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^2.0.74",
    "@ai-sdk/provider-utils": "^2.0.6",
    "@anthropic-ai/sdk": "^0.55.1",
    "@dqbd/tiktoken": "^1.0.21",
    "@google/genai": "1.30.0",
    "@vybestack/llxprt-code-core": "file:../core",
    "ai": "^5.0.104",
    "openai": "^5.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@vybestack/llxprt-code-test-utils": "file:../test-utils",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}

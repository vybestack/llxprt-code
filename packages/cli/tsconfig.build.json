{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@vybestack/llxprt-code-agents": ["../agents/dist/index.d.ts"],
      "@vybestack/llxprt-code-core": ["../core/dist/index.d.ts"],
      "@vybestack/llxprt-code-core/*": ["../core/dist/src/*"],
      "@vybestack/llxprt-code-mcp": ["../mcp/dist/mcp/index.d.ts"],
      "@vybestack/llxprt-code-mcp/*": ["../mcp/dist/mcp/src/*"],
      "@vybestack/llxprt-code-providers": ["../providers/dist/index.d.ts"],
      "@vybestack/llxprt-code-providers/*": ["../providers/dist/src/*"]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.json",
    "./package.json"
  ]
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/cli.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "composite": false,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "rootDir": "..",
    "paths": {
      "@vybestack/llxprt-code-auth": ["../auth/src/index.ts"],
      "@vybestack/llxprt-code-agents": ["../agents/index.ts"],
      "@vybestack/llxprt-code-core": ["../core/index.ts"],
      "@vybestack/llxprt-code-core/*": ["../core/src/*"],
      "@vybestack/llxprt-code-ide-integration": ["../ide-integration/index.ts"],
      "@vybestack/llxprt-code-ide-integration/*": ["../ide-integration/src/*"],
      "@vybestack/llxprt-code-mcp": ["../mcp/index.ts"],
      "@vybestack/llxprt-code-mcp/*": ["../mcp/src/*"],
      "@vybestack/llxprt-code-providers": ["../providers/index.ts"],
      "@vybestack/llxprt-code-providers/auth.js": [
        "../providers/src/auth/index.ts"
      ],
      "@vybestack/llxprt-code-providers/composition.js": [
        "../providers/src/composition/index.ts"
      ],
      "@vybestack/llxprt-code-providers/*": ["../providers/src/*"],
      "@vybestack/llxprt-code-settings": ["../settings/index.ts"],
      "@vybestack/llxprt-code-settings/*": ["../settings/src/*"]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.json",
    "./package.json",
    "../providers/index.ts",
    "../providers/src/**/*.ts",
    "../providers/src/**/*.json",
    "../auth/src/index.ts",
    "../auth/src/**/*.ts",
    "../mcp/index.ts",
    "../mcp/src/**/*.ts",
    "../mcp/src/**/*.d.ts",
    "../settings/index.ts",
    "../settings/src/**/*.ts",
    "../ide-integration/index.ts",
    "../ide-integration/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../providers/src/**/*.test.ts",
    "../providers/src/**/*.spec.ts",
    "../auth/src/**/*.test.ts",
    "../auth/src/**/*.spec.ts",
    "../mcp/src/**/*.test.ts",
    "../mcp/src/**/*.spec.ts",
    "../settings/src/**/*.test.ts",
    "../settings/src/**/*.spec.ts",
    "../ide-integration/src/**/*.test.ts",
    "../ide-integration/src/**/*.spec.ts",

    // TODO(5691): Fix type errors and remove excludes.
    "src/config/config.integration.test.ts",
    "src/config/config.test.ts",
    "src/config/extension.test.ts",
    "src/config/settings.test.ts",
    "src/nonInteractiveCli.test.ts",
